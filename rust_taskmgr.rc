// Win32 资源定义入口。
// 这里集中声明程序清单、位图、对话框、菜单和版本资源，Rust 侧通过固定资源 ID 与之协作。
#include "windows.h"
#include "commctrl.h"

LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US
#pragma code_page(1252)

// 绑定应用清单，控制常用控件版本和 DPI/权限等基础行为。
1 24 "sysmon.manifest"

// 位图资源主要用于性能页和自绘控件。
102 BITMAP DISCARDABLE "numbers.bmp"
103 BITMAP DISCARDABLE "ledlit.bmp"
104 BITMAP DISCARDABLE "ledunlit.bmp"
114 BITMAP DISCARDABLE "bmpback.bmp"
115 BITMAP DISCARDABLE "bmpforwa.bmp"
125 BITMAP DISCARDABLE "bitmap1.bmp"
126 BITMAP DISCARDABLE "bmp00001.bmp"
127 BITMAP DISCARDABLE "bitmap2.bmp"

105 DIALOG DISCARDABLE 0, 0, 264, 247
STYLE DS_3DLOOK | WS_POPUP | WS_CAPTION | WS_THICKFRAME
MENU 106
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "Tab1", 1000, "SysTabControl32", WS_TABSTOP, 3, 3, 91, 116
END

