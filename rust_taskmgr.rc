109 DIALOGEX 0, 0, 438, 303
STYLE DS_CONTROL | WS_CHILD
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    CONTROL "List1", 2600, "SysListView32", LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP, 9, 9, 376, 131
    LTEXT "No Active Network Adapters Found.", 2603, 66, 144, 262, 8, SS_CENTER
    SCROLLBAR 2606, 390, 9, 10, 131, SBS_VERT | WS_TABSTOP
END

110 DIALOG DISCARDABLE 0, 0, 393, 197
STYLE DS_3DLOOK | DS_CONTROL | WS_CHILD
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "List2", 1009, "SysListView32", LVS_REPORT | LVS_SINGLESEL | WS_BORDER | WS_TABSTOP, 9, 9, 376, 131
    PUSHBUTTON "&End Process", 1010, 320, 144, 66, 14
END

112 DIALOG DISCARDABLE 0, 0, 393, 177
STYLE DS_3DLOOK | DS_CONTROL | WS_CHILD
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL "List2", 1053, "SysListView32", LVS_REPORT | WS_BORDER | WS_TABSTOP, 9, 9, 378, 139
    DEFPUSHBUTTON "&Switch To", 1048, 280, 152, 53, 14
    PUSHBUTTON "&End Task", 1050, 224, 152, 53, 14
    DEFPUSHBUTTON "&New Task...", 40001, 336, 152, 53, 14
END

121 DIALOG DISCARDABLE 20, 20, 191, 141
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Select Columns"
FONT 8, "MS Shell Dlg"
BEGIN
    DEFPUSHBUTTON "OK", IDOK, 83, 122, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 137, 122, 50, 14
